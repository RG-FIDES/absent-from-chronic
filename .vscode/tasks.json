      "problemMatcher": []
    },
    {
      "label": "Run EDA-3 Pipeline",
      "detail": "Run eda-3.R then render eda-3.qmd",
      "type": "shell",
      "command": "Rscript analysis/eda-3/eda-3.R ; quarto render analysis/eda-3/eda-3.qmd",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "problemMatcher": []
    },

    // ── Log maintenance ───────────────────────────────────────────────────────
    {
      "label": "Clean Expired Logs",
      "detail": "Delete log directories older than LOG_RETENTION_DAYS (set in .env) from data-private/logs/",
      "type": "shell",
      "command": "powershell",
      "args": ["-ExecutionPolicy", "Bypass", "-File", "utility/clean-logs.ps1"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": []
    }
