      "problemMatcher": []
    },
    {
      "label": "Run  Pipeline (flow.R)",
      "detail": "Guided menu: choose Ellis mode, EDAs, and run mode; patches files automatically",
      "type": "shell",
      "command": "powershell",
      "args": ["-ExecutionPolicy", "Bypass", "-File", "scripts/ps1/run-interactive-flow.ps1"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "new" },
      "problemMatcher": []
    },

    // ── Pipeline stages (direct Rscript) ─────────────────────────────────────
    {
      "label": "Run Pipeline (flow.R)",
      "detail": "Execute complete pipeline: ferry → ellis → eda (Rscript flow.R)",
      "type": "shell",
      "command": "Rscript",
      "args": ["flow.R"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "problemMatcher": []
    },
    {
      "label": "Run Ferry Lane 1",
      "detail": "Import CCHS .sav files → cchs-1.sqlite (manipulation/1-ferry.R)",
      "type": "shell",
      "command": "Rscript",
      "args": ["manipulation/1-ferry.R"],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "problemMatcher": []
    },
    {
      "label": "Run Ellis Lane 2",
      "detail": "Transform cchs-1.sqlite → cchs-2.sqlite + Parquet (manipulation/2-ellis.R)",
      "type": "shell",
      "command": "Rscript",
      "args": ["manipulation/2-ellis.R"],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "problemMatcher": []
    },

    // ── Analysis stages (R script + QMD combined) ────────────────────────────
    {
      "label": "Run EDA-1 Pipeline",
      "detail": "Run eda-1.R then render eda-1.qmd",
      "type": "shell",
      "command": "Rscript analysis/eda-1/eda-1.R ; quarto render analysis/eda-1/eda-1.qmd",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "problemMatcher": []
    },
    {
      "label": "Run EDA-2 Pipeline",
      "detail": "Run eda-2.R then render eda-2.qmd",
      "type": "shell",
      "command": "Rscript analysis/eda-2/eda-2.R ; quarto render analysis/eda-2/eda-2.qmd",
